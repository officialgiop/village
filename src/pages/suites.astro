---
import '../styles/global.css';

const whatsappNumber = '393330000000';
const basePath = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const withBase = (path: string) => `${basePath}${path}`;
const homePath = basePath;
const logoPath = withBase('logo.png');
const faviconSvgPath = withBase('favicon.svg');
const faviconIcoPath = withBase('favicon.ico');
const baseTemplate = `Ciao Village Fregene Padel & Suites, vorrei richiedere disponibilita per:`;
const buildWaLink = (roomType: string) =>
	`https://wa.me/${whatsappNumber}?text=${encodeURIComponent(`${baseTemplate} ${roomType}

Check-in:
Check-out:
Numero ospiti:
Evento (se presente):
Note:`)}`;
---

<html lang="it">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={faviconSvgPath} />
		<link rel="icon" href={faviconIcoPath} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Suites | Village Fregene Padel & Suites</title>
		<meta
			name="description"
			content="Scopri Stanza Singola, Stanza Doppia e Stanza Tripla al Village Fregene Padel & Suites. Prenota via WhatsApp in pochi secondi."
		/>
	</head>
	<body class="selection:bg-brand-200 selection:text-brand-900">
		<header class="mx-auto max-w-6xl px-4 pb-8 pt-6 sm:px-6">
			<nav class="glass-card flex items-center justify-between p-4">
				<a href={homePath} class="flex items-center gap-3">
					<img src={logoPath} alt="Village Fregene Padel logo" class="h-10 w-10 rounded-full bg-black/5 p-1 object-contain" />
					<span class="font-display text-base font-bold tracking-tight text-brand-900 sm:text-lg">
						Village Fregene Padel & Suites
					</span>
				</a>
				<a href={homePath} class="text-sm font-semibold text-brand-700 hover:text-brand-900">← Torna alla home</a>
			</nav>
		</header>

		<main class="mx-auto max-w-6xl space-y-14 px-4 pb-16 sm:px-6">
			<section class="relative overflow-hidden rounded-3xl border border-brand-100 bg-gradient-to-br from-brand-700 via-brand-800 to-brand-900 p-7 text-white sm:p-10">
				<div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-white/10 blur-2xl"></div>
				<div class="absolute -left-10 bottom-0 h-32 w-32 rounded-full bg-accent/40 blur-2xl"></div>
				<p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/80">Suites Experience</p>
				<h1 class="mt-2 font-display text-4xl font-bold leading-tight sm:text-5xl">
					La tua stanza perfetta dopo il match.
				</h1>
				<p class="mt-4 max-w-2xl text-base text-white/90 sm:text-lg">
					Comfort, stile e praticita: ogni suite dispone di uno spazio esterno privato con tavolo e angolo cottura, ideale per vivere Fregene senza pensieri.
				</p>
				<div class="mt-6 flex flex-wrap gap-3">
					<a
						href={buildWaLink('Stanza Doppia')}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-1 rounded-full bg-white px-5 py-3 text-sm font-semibold text-brand-900 hover:bg-brand-50"
					>
						<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" aria-hidden="true" stroke="currentColor" stroke-width="1.8">
							<rect x="3.5" y="5.5" width="17" height="15" rx="2" />
							<path d="M7.5 3.5v4M16.5 3.5v4M3.5 9.5h17M8 13h3M13 13h3M8 17h3" />
						</svg>
						Prenota ora su WhatsApp
					</a>
					<a href="#tipologie" class="rounded-full border border-white/40 px-5 py-3 text-sm font-semibold text-white hover:bg-white/10">
						Scopri le tipologie
					</a>
				</div>
			</section>

			<section id="tipologie" class="space-y-5">
				<div class="flex items-end justify-between">
					<h2 class="font-display text-3xl font-bold text-slate-900">Tipologie di camere</h2>
					<p class="text-sm text-slate-600">Scegli la formula migliore per il tuo soggiorno</p>
				</div>
				<div class="grid gap-5 md:grid-cols-3">
					<article class="glass-card hover-lift p-6">
						<p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-700">Stanza Singola</p>
						<h3 class="mt-2 font-display text-2xl font-bold">Privacy totale</h3>
						<p class="mt-3 text-sm text-slate-700">
							Camera doppia in uso singola: piu spazio, piu tranquillita, perfetta per chi viaggia da solo e vuole riposare bene dopo allenamenti o eventi.
						</p>
						<ul class="mt-4 space-y-2 text-sm text-slate-700">
							<li>• Comfort extra rispetto alla classica singola</li>
							<li>• Spazio pratico per valigia e borsa sportiva</li>
							<li>• Ideale per soggiorni business o sportivi</li>
						</ul>
						<a
							href={buildWaLink('Stanza Singola')}
							target="_blank"
							rel="noopener noreferrer"
							class="mt-5 inline-flex items-center gap-1 rounded-full bg-accent px-4 py-2 text-xs font-semibold text-white hover:opacity-90"
						>
							<svg viewBox="0 0 24 24" fill="none" class="h-3.5 w-3.5" aria-hidden="true" stroke="currentColor" stroke-width="1.8">
								<rect x="3.5" y="5.5" width="17" height="15" rx="2" />
								<path d="M7.5 3.5v4M16.5 3.5v4M3.5 9.5h17M8 13h3M13 13h3M8 17h3" />
							</svg>
							Richiedi disponibilita
						</a>
					</article>
					<article class="glass-card hover-lift p-6">
						<p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-700">Stanza Doppia</p>
						<h3 class="mt-2 font-display text-2xl font-bold">La piu richiesta</h3>
						<p class="mt-3 text-sm text-slate-700">
							Stanza matrimoniale accogliente e luminosa, pensata per coppie o due ospiti che cercano un soggiorno comodo vicino al circolo.
						</p>
						<ul class="mt-4 space-y-2 text-sm text-slate-700">
							<li>• Letto matrimoniale e atmosfera rilassante</li>
							<li>• Ideale per soggiorni di una settimana o piu</li>
							<li>• Ottimo equilibrio tra comfort e convenienza</li>
						</ul>
						<a
							href={buildWaLink('Stanza Doppia')}
							target="_blank"
							rel="noopener noreferrer"
							class="mt-5 inline-flex items-center gap-1 rounded-full bg-accent px-4 py-2 text-xs font-semibold text-white hover:opacity-90"
						>
							<svg viewBox="0 0 24 24" fill="none" class="h-3.5 w-3.5" aria-hidden="true" stroke="currentColor" stroke-width="1.8">
								<rect x="3.5" y="5.5" width="17" height="15" rx="2" />
								<path d="M7.5 3.5v4M16.5 3.5v4M3.5 9.5h17M8 13h3M13 13h3M8 17h3" />
							</svg>
							Richiedi disponibilita
						</a>
					</article>
					<article class="glass-card hover-lift p-6">
						<p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-700">Stanza Tripla</p>
						<h3 class="mt-2 font-display text-2xl font-bold">Per team e gruppi</h3>
						<p class="mt-3 text-sm text-slate-700">
							Soluzione ideale per famiglie con un bambino: piu posti letto e organizzazione intelligente degli spazi.
						</p>
						<ul class="mt-4 space-y-2 text-sm text-slate-700">
							<li>• Perfetta per 2 adulti + 1 bambino</li>
							<li>• Piu comodita per soggiorni di piu giorni</li>
							<li>• Conveniente per vacanze e tornei in famiglia</li>
						</ul>
						<a
							href={buildWaLink('Stanza Tripla')}
							target="_blank"
							rel="noopener noreferrer"
							class="mt-5 inline-flex items-center gap-1 rounded-full bg-accent px-4 py-2 text-xs font-semibold text-white hover:opacity-90"
						>
							<svg viewBox="0 0 24 24" fill="none" class="h-3.5 w-3.5" aria-hidden="true" stroke="currentColor" stroke-width="1.8">
								<rect x="3.5" y="5.5" width="17" height="15" rx="2" />
								<path d="M7.5 3.5v4M16.5 3.5v4M3.5 9.5h17M8 13h3M13 13h3M8 17h3" />
							</svg>
							Richiedi disponibilita
						</a>
					</article>
				</div>
			</section>

			<section class="grid gap-5 lg:grid-cols-[1.1fr_1fr]">
				<div class="glass-card p-6">
					<h2 class="font-display text-2xl font-bold">Servizi inclusi nelle suites</h2>
					<div class="mt-4 grid gap-3 sm:grid-cols-2">
						<div class="rounded-xl bg-white p-4 text-sm font-medium text-slate-700 shadow-sm">
							<span class="mr-2 inline-flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 text-brand-800">
								<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-width="1.8">
									<path d="M12 3v18M3 12h18M5.5 5.5l13 13M18.5 5.5l-13 13" />
								</svg>
							</span>Aria condizionata
						</div>
						<div class="rounded-xl bg-white p-4 text-sm font-medium text-slate-700 shadow-sm">
							<span class="mr-2 inline-flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 text-brand-800">
								<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-width="1.8">
									<path d="M4 9a8 8 0 0 1 16 0" />
									<path d="M7 12a5 5 0 0 1 10 0" />
									<path d="M10 15a2 2 0 0 1 4 0" />
									<circle cx="12" cy="18" r="1.2" fill="currentColor" stroke="none" />
								</svg>
							</span>Wi-Fi veloce
						</div>
						<div class="rounded-xl bg-white p-4 text-sm font-medium text-slate-700 shadow-sm">
							<span class="mr-2 inline-flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 text-brand-800">
								<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-width="1.8">
									<path d="M4 8h16" />
									<path d="M6 8v9a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V8" />
									<path d="M9 8V6a3 3 0 0 1 6 0v2" />
								</svg>
							</span>Cucina attrezzata
						</div>
						<div class="rounded-xl bg-white p-4 text-sm font-medium text-slate-700 shadow-sm">
							<span class="mr-2 inline-flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 text-brand-800">
								<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-width="1.8">
									<path d="M7 4h10v16H7z" />
									<path d="M10 10h4M10 14h4" />
								</svg>
							</span>1 bagno
						</div>
						<div class="rounded-xl bg-white p-4 text-sm font-medium text-slate-700 shadow-sm sm:col-span-2">
							<span class="mr-2 inline-flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 text-brand-800">
								<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-width="1.8">
									<path d="M4 14h16" />
									<path d="M7 14v5M17 14v5" />
									<path d="M7 10l3-3M17 10l-3-3" />
								</svg>
							</span>Spazio esterno privato con tavolo e angolo cottura
						</div>
						<div class="rounded-xl bg-white p-4 text-sm font-medium text-slate-700 shadow-sm sm:col-span-2">
							<span class="mr-2 inline-flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 text-brand-800">
								<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-width="1.8">
									<path d="M4 6h16v4H4z" />
									<path d="M6 10v8h12v-8" />
									<path d="M9 14h6" />
								</svg>
							</span>Cambio biancheria e riassetto: 1 volta a settimana
						</div>
					</div>
				</div>
				<div class="rounded-2xl border border-accent/20 bg-gradient-to-br from-accent/10 to-white p-6">
					<p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Offerte speciali</p>
					<h3 class="mt-2 font-display text-2xl font-bold text-slate-900">Formule scontate</h3>
					<ul class="mt-4 space-y-3 text-sm text-slate-700">
						<li>• Sconti dedicati per periodi con eventi e tornei.</li>
						<li>• Tariffe agevolate per soggiorni oltre 3 settimane.</li>
						<li>• Condizioni personalizzate per gruppi sportivi.</li>
					</ul>
					<a
						href={buildWaLink('Offerta soggiorno con formula scontata')}
						target="_blank"
						rel="noopener noreferrer"
						class="mt-5 inline-flex items-center gap-1 rounded-full bg-accent px-4 py-2 text-xs font-semibold text-white hover:opacity-90"
					>
						<svg viewBox="0 0 24 24" fill="none" class="h-3.5 w-3.5" aria-hidden="true" stroke="currentColor" stroke-width="1.8">
							<rect x="3.5" y="5.5" width="17" height="15" rx="2" />
							<path d="M7.5 3.5v4M16.5 3.5v4M3.5 9.5h17M8 13h3M13 13h3M8 17h3" />
						</svg>
						Chiedi la migliore offerta
					</a>
				</div>
			</section>

			<section class="space-y-4">
				<div class="flex items-end justify-between">
					<h2 class="font-display text-2xl font-bold">Gallery suites</h2>
					<p class="text-sm text-slate-600">Foto dimostrative, sostituibili con i tuoi contenuti</p>
				</div>
				<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
					<img class="h-48 w-full rounded-xl object-cover shadow-sm hover-lift" src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1200&q=80" alt="Camera da letto luminosa con arredi moderni" loading="lazy" />
					<img class="h-48 w-full rounded-xl object-cover shadow-sm hover-lift" src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?auto=format&fit=crop&w=1200&q=80" alt="Stanza doppia con dettagli di design" loading="lazy" />
					<img class="h-48 w-full rounded-xl object-cover shadow-sm hover-lift" src="https://images.unsplash.com/photo-1560448204-603b3fc33ddc?auto=format&fit=crop&w=1200&q=80" alt="Cucina della suite attrezzata" loading="lazy" />
					<img class="h-48 w-full rounded-xl object-cover shadow-sm hover-lift" src="https://images.unsplash.com/photo-1566665797739-1674de7a421a?auto=format&fit=crop&w=1200&q=80" alt="Bagno moderno della suite" loading="lazy" />
				</div>
			</section>

			<section class="space-y-4">
				<h2 class="font-display text-2xl font-bold">Video rooms tour</h2>
				<div class="grid gap-4 lg:grid-cols-2">
					<div class="overflow-hidden rounded-2xl border border-slate-200 bg-black shadow-sm hover-lift">
						<iframe
							class="aspect-video w-full"
							src="https://www.youtube.com/embed/9Fpzv4Qj8eM"
							title="Rooms tour Village Fregene Padel Suites"
							loading="lazy"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
							referrerpolicy="strict-origin-when-cross-origin"
							allowfullscreen
						></iframe>
					</div>
					<div class="overflow-hidden rounded-2xl border border-slate-200 bg-black shadow-sm hover-lift">
						<iframe
							class="aspect-video w-full"
							src="https://www.youtube.com/embed/9LQkIY6phhM"
							title="Esperienza soggiorno e padel"
							loading="lazy"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
							referrerpolicy="strict-origin-when-cross-origin"
							allowfullscreen
						></iframe>
					</div>
				</div>
			</section>

			<section class="rounded-3xl border border-brand-100 bg-white p-7 text-center shadow-soft">
				<h2 class="font-display text-3xl font-bold text-slate-900">Pronto a prenotare la tua stanza?</h2>
				<p class="mx-auto mt-3 max-w-2xl text-sm text-slate-700 sm:text-base">
					Scrivici su WhatsApp con date e numero ospiti: ti rispondiamo rapidamente con disponibilita e proposta migliore.
				</p>
				<a
					href={buildWaLink('Stanza Singola / Doppia / Tripla')}
					target="_blank"
					rel="noopener noreferrer"
					class="mt-6 inline-flex items-center gap-1 rounded-full bg-accent px-6 py-3 text-sm font-semibold text-white hover:opacity-90"
				>
					<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" aria-hidden="true" stroke="currentColor" stroke-width="1.8">
						<rect x="3.5" y="5.5" width="17" height="15" rx="2" />
						<path d="M7.5 3.5v4M16.5 3.5v4M3.5 9.5h17M8 13h3M13 13h3M8 17h3" />
					</svg>
					Prenota ora su WhatsApp
				</a>
			</section>
		</main>
	</body>
</html>

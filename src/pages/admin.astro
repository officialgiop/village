			function quarterDateRange(year, quarter) {
				const startMonth = (quarter - 1) * 3;
				const start = new Date(Date.UTC(year, startMonth, 1));
				const end = new Date(Date.UTC(year, startMonth + 3, 0, 23, 59, 59));
				return { start, end };
			}

			function transactionInQuarter(tx, year, quarter) {
				const date = new Date(`${tx.date}T00:00:00Z`);
				const { start, end } = quarterDateRange(year, quarter);
				return date >= start && date <= end;
			}

			function updateQuarterSummary() {
				const allRows = clubData.transactions;
				const total = allRows.reduce((sum, tx) => sum + tx.amount, 0);
				const bancomat = allRows
					.filter((tx) => tx.paymentMethod === 'Bancomat')
					.reduce((sum, tx) => sum + tx.amount, 0);
				const contanti = allRows
					.filter((tx) => tx.paymentMethod === 'Contanti')
					.reduce((sum, tx) => sum + tx.amount, 0);
				summaryTotal.textContent = formatCurrency(total);
				summaryBancomat.textContent = formatCurrency(bancomat);
				summaryContanti.textContent = formatCurrency(contanti);
			}

			function buildReportRows(year, quarter, paymentFilter) {
				return clubData.transactions
					.filter((tx) => {
						if (!transactionInQuarter(tx, year, quarter)) return false;
						if (paymentFilter === 'all') return true;
						return tx.paymentMethod === paymentFilter;
					})
					.sort((a, b) => (a.date > b.date ? 1 : -1))
					.map((tx) => {
						const person = resolveTransactionPerson(tx);
						return {
							receiptId: tx.receiptId,
							date: tx.date,
							client: person.client,
							taxCode: person.taxCode,
							expenseType: tx.expenseType,
							amount: tx.amount
						};
					});
			}

			reportForm.addEventListener('submit', async (event) => {
				event.preventDefault();
				const year = Number.parseInt(reportYearInput.value, 10);
				const quarter = Number.parseInt(reportQuarterInput.value, 10);
				const paymentFilter = reportPaymentFilterInput.value;
				const rows = buildReportRows(year, quarter, paymentFilter);
				if (rows.length === 0) {
					notify('receipts', `Nessun dato disponibile per Q${quarter} ${year} con il filtro selezionato.`, 'info');
					return;
				}

				try {
					const jsPDF = await ensurePdfLibraries();
					const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
					doc.setFontSize(16);
					doc.text(`Village - Report trimestrale Q${quarter} ${year}`, 14, 16);
					doc.setFontSize(10);
					doc.text(`Generato il ${new Date().toLocaleDateString('it-IT')}`, 14, 22);

					if (typeof doc.autoTable === 'function') {
						doc.autoTable({
							startY: 28,
							styles: { fontSize: 9 },
							head: [['ID ricevuta', 'Data', 'Cliente', 'Codice fiscale', 'Tipo spesa', 'Importo']],
							body: rows.map((row) => [
								row.receiptId,
								formatDateIt(row.date),
								row.client,
								row.taxCode,
								row.expenseType,
								formatCurrency(row.amount)
							])
						});
						const total = rows.reduce((sum, row) => sum + row.amount, 0);
						doc.text(`Totale trimestre: ${formatCurrency(total)}`, 14, doc.lastAutoTable.finalY + 10);
					} else {
						let y = 30;
						rows.forEach((row) => {
							if (y > 280) {
								doc.addPage();
								y = 16;
							}
							doc.text(
								`${row.receiptId} | ${formatDateIt(row.date)} | ${row.client} | ${row.taxCode} | ${row.expenseType} | ${formatCurrency(row.amount)}`,
								14,
								y
							);
							y += 6;
						});
						const total = rows.reduce((sum, row) => sum + row.amount, 0);
						doc.text(`Totale trimestre: ${formatCurrency(total)}`, 14, y + 6);
					}

					doc.save(`village-report-q${quarter}-${year}.pdf`);
					notify('receipts', `PDF Q${quarter} ${year} generato con successo.`, 'success');
				} catch (error) {
					notify('receipts', error.message || 'Errore durante la generazione del PDF.', 'error');
				}
			});

			bulkGenerateReceiptsButton.addEventListener('click', async () => {
				const missing = clubData.transactions
					.filter((tx) => !tx.receiptGenerated)
					.sort((a, b) => Number.parseInt(a.receiptId, 10) - Number.parseInt(b.receiptId, 10));
				if (missing.length === 0) {
					notify('receipts', 'Tutte le ricevute risultano gia generate.', 'info');
					return;
				}

				try {
					let selectedDirectory = null;
					const canPickDirectory = 'showDirectoryPicker' in window;
					if (canPickDirectory) {
						selectedDirectory = await window.showDirectoryPicker();
					}
					showBulkSaveOverlay(missing.length);
					for (let index = 0; index < missing.length; index += 1) {
						const tx = missing[index];
						const doc = await buildReceiptDocument([tx]);
						const fileName = `ricevuta-${tx.receiptId}.pdf`;
						if (selectedDirectory) {
							await savePdfToDirectoryHandle(doc, selectedDirectory, fileName);
						} else {
							await savePdfWithPickerOrDownload(doc, fileName);
						}
						updateBulkSaveProgress(index + 1, missing.length);
					}

					const previous = missing.map((tx) => ({ id: tx.id, receiptGenerated: tx.receiptGenerated, receiptGeneratedAt: tx.receiptGeneratedAt }));
					const stamp = new Date().toISOString();
					missing.forEach((tx) => {
						tx.receiptGenerated = true;
						tx.receiptGeneratedAt = stamp;
					});
					try {
						await saveDataToGitHub(`Genera ricevute mancanti (${missing.length})`);
					} catch (saveError) {
						previous.forEach((item) => {
							const target = clubData.transactions.find((tx) => tx.id === item.id);
							if (!target) return;
							target.receiptGenerated = item.receiptGenerated;
							target.receiptGeneratedAt = item.receiptGeneratedAt;
						});
						renderTransactionsTable();
						throw saveError;
					}
					renderTransactionsTable();
					if (selectedDirectory) {
						notify('receipts', `Generate ${missing.length} ricevute mancanti nella cartella selezionata.`, 'success');
					} else {
						notify('receipts', `Generate ${missing.length} ricevute mancanti in file separati.`, 'success');
					}
				} catch (error) {
					notify('receipts', error.message || 'Errore durante la generazione bulk delle ricevute.', 'error');
				} finally {
					hideBulkSaveOverlay();
				}
			});

			bootstrapAuth();
			fillConfigForm();
			closeConfigPanel();
			closeMembersPanel();
			loadClubDataFromGitHub();
		</script>
	</body>
</html>

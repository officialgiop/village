			function normalizeFullName(name, surname) {
				const full = `${name || ''} ${surname || ''}`.trim().toLowerCase();
				return full.replace(/\s+/g, ' ');
			}

			function reconcileTransactionsWithMembers() {
				const memberById = new Map(clubData.members.map((member) => [member.id, member]));
				const membersByName = new Map();
				clubData.members.forEach((member) => {
					const key = normalizeFullName(member.name, member.surname);
					const bucket = membersByName.get(key) || [];
					bucket.push(member);
					membersByName.set(key, bucket);
				});

				clubData.transactions = clubData.transactions.map((tx) => {
					const linked = tx.memberId ? memberById.get(tx.memberId) : null;
					if (linked) {
						return {
							...tx,
							memberName: linked.name,
							memberSurname: linked.surname,
							memberTaxCode: linked.taxCode,
							hasIssue: false,
							issue: '',
							candidateMemberIds: undefined
						};
					}

					const key = normalizeFullName(tx.memberName, tx.memberSurname);
					const matches = key ? membersByName.get(key) || [] : [];
					if (matches.length === 1) {
						const member = matches[0];
						return {
							...tx,
							memberId: member.id,
							memberName: member.name,
							memberSurname: member.surname,
							memberTaxCode: member.taxCode,
							hasIssue: false,
							issue: '',
							candidateMemberIds: undefined
						};
					}

					return {
						...tx,
						memberId: null,
						memberTaxCode: '#N/A',
						hasIssue: true,
						issue: matches.length > 1 ? 'member_ambiguous' : 'member_not_found',
						candidateMemberIds: matches.length > 1 ? matches.map((member) => member.id) : undefined
					};
				});
			}

			function renderAll() {
				reconcileTransactionsWithMembers();
				renderMembersTable();
				renderMemberOptions();
				renderExpenseTypeOptions();
				renderExpenseTypesEditor();
				renderPaymentMethodOptions();
				renderPaymentMethodsEditor();
				renderTransactionsTable();
				updateQuarterSummary();
				updateReceiptField();
			}

			async function loadClubDataFromPublic() {
				try {
					const response = await fetch(dataPath, { cache: 'no-store' });
					if (!response.ok) throw new Error('Impossibile leggere il file dati pubblico.');
					const payload = await response.json();
					clubData = {
						members: Array.isArray(payload.members) ? payload.members : [],
						transactions: Array.isArray(payload.transactions) ? payload.transactions : [],
						settings:
							payload.settings && typeof payload.settings === 'object'
								? payload.settings
								: {
									expenseTypes: [...DEFAULT_EXPENSE_TYPES],
									paymentMethods: [...DEFAULT_PAYMENT_METHODS]
								}
					};
				} catch (error) {
					console.error(error);
					clubData = {
						members: [],
						transactions: [],
						settings: {
							expenseTypes: [...DEFAULT_EXPENSE_TYPES],
							paymentMethods: [...DEFAULT_PAYMENT_METHODS]
						}
					};
				}
				renderAll();
			}

			async function loadClubDataFromGitHub() {
				const config = getGitHubConfig();
				if (!config || !config.owner || !config.repo || !config.branch || !config.dataPath || !config.token) {
					await loadClubDataFromPublic();
					return;
				}
				try {
					const url = `https://api.github.com/repos/${config.owner}/${config.repo}/contents/${config.dataPath}?ref=${encodeURIComponent(config.branch)}`;
					const response = await fetch(url, {
						headers: {
							Authorization: `Bearer ${config.token}`,
							Accept: 'application/vnd.github+json'
						},
						cache: 'no-store'
					});
					if (!response.ok) throw new Error('Impossibile leggere il file dati da GitHub.');
					const payload = await response.json();
					const decoded = fromBase64Unicode(String(payload.content || '').replace(/\n/g, ''));
					const parsed = parseJSONSafely(decoded, { members: [], transactions: [] });
					clubData = {
						members: Array.isArray(parsed.members) ? parsed.members : [],
						transactions: Array.isArray(parsed.transactions) ? parsed.transactions : [],
						settings:
							parsed.settings && typeof parsed.settings === 'object'
								? parsed.settings
								: {
									expenseTypes: [...DEFAULT_EXPENSE_TYPES],
									paymentMethods: [...DEFAULT_PAYMENT_METHODS]
								}
					};
				} catch (error) {
					console.error(error);
					await loadClubDataFromPublic();
					return;
				}
				renderAll();
			}

			function toBase64Unicode(value) {
				return btoa(unescape(encodeURIComponent(value)));
			}

			function fromBase64Unicode(value) {
				return decodeURIComponent(escape(atob(value)));
			}

			async function getCurrentFileSha(config) {
				const url = `https://api.github.com/repos/${config.owner}/${config.repo}/contents/${config.dataPath}?ref=${encodeURIComponent(config.branch)}`;
				const response = await fetch(url, {
					headers: {
						Authorization: `Bearer ${config.token}`,
						Accept: 'application/vnd.github+json'
					}
				});
				if (!response.ok) {
					throw new Error('Impossibile leggere il file dati su GitHub.');
				}
				const payload = await response.json();
				return payload.sha;
			}

			async function putDataToGitHub(config, sha, commitMessage) {
				const url = `https://api.github.com/repos/${config.owner}/${config.repo}/contents/${config.dataPath}`;
				const body = {
					message: commitMessage,
					branch: config.branch,
					sha,
					content: toBase64Unicode(JSON.stringify(clubData, null, 2))
				};
				const response = await fetch(url, {
					method: 'PUT',
					headers: {
						Authorization: `Bearer ${config.token}`,
						Accept: 'application/vnd.github+json',
						'Content-Type': 'application/json'
					},
					body: JSON.stringify(body)
				});
				if (response.ok) return;
				const error = await response.json().catch(() => ({}));
				throw new Error(error.message || 'Errore durante il salvataggio su GitHub.');
			}

			function saveDataToGitHub(commitMessage) {
				const runSave = async () => {
					const config = getGitHubConfig();
					if (!config) throw new Error('Configurazione GitHub non trovata.');
					const maxAttempts = 6;
					for (let attempt = 1; attempt <= maxAttempts; attempt += 1) {
						try {
							const sha = await getCurrentFileSha(config);
							await putDataToGitHub(config, sha, commitMessage);
							return;
						} catch (error) {
							const message = String(error?.message || '');
							const isShaConflict = message.includes('does not match');
							const isLastAttempt = attempt === maxAttempts;
							if (!isShaConflict || isLastAttempt) {
								if (isShaConflict && isLastAttempt) {
									throw new Error('Conflitto di salvataggio ripetuto. Riprova tra qualche secondo.');
								}
								throw error;
							}
						}
					}
				};

				saveQueue = saveQueue.then(runSave, runSave);
				return saveQueue;
			}


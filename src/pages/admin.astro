---
import '../styles/global.css';

const basePath = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const withBase = (path: string) => `${basePath}${path}`;
const homePath = basePath;
const logoPath = withBase('logo-cropped.png');
const logoReceiptPath = withBase('logo-ricevuta.png');
const dataPath = withBase('data/club-data.json');
---

<html lang="it">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Dashboard amministrazione | Village</title>
		<meta name="robots" content="noindex, nofollow" />
	</head>
	<body class="selection:bg-brand-200 selection:text-brand-900">
		<main class="mx-auto max-w-6xl space-y-6 px-4 py-6 sm:px-6">
			<header class="glass-card flex flex-col gap-4 p-4 sm:flex-row sm:items-center sm:justify-between">
				<div class="flex items-center gap-3">
					<img src={logoPath} alt="Village logo" class="h-14 w-14 object-contain" />
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-700">Area gestione</p>
						<h1 class="font-display text-2xl font-bold text-slate-900">Dashboard segreteria</h1>
					</div>
				</div>
				<a href={homePath} class="text-sm font-semibold text-brand-700 hover:text-brand-900">← Torna al sito</a>
			</header>

			<section id="authBox" class="glass-card p-6">
				<h2 class="font-display text-xl font-semibold text-slate-900">Accesso rapido</h2>
				<p class="mt-2 text-sm text-slate-700">
					Questa e una protezione leggera lato browser adatta solo a una demo. Imposta una password semplice e condividila con la segreteria.
				</p>
				<form id="unlockForm" class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end">
					<label class="flex-1 text-sm">
						<span class="mb-1 block font-medium text-slate-700">Password dashboard</span>
						<input
							id="adminPasswordInput"
							type="password"
							required
							class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm focus:border-brand-600 focus:outline-none"
							placeholder="Inserisci password"
						/>
					</label>
					<button type="submit" class="rounded-xl bg-brand-700 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-800">
						Entra
					</button>
				</form>
				<p id="authStatus" class="status-message hidden" role="status"></p>
			</section>

			<section id="adminApp" class="hidden space-y-6">
				<div id="adminGlobalStatus" class="status-message hidden" role="status" aria-live="polite"></div>
				<section class="glass-card p-5">
					<div class="flex flex-wrap items-center justify-between gap-3">
						<h2 class="font-display text-xl font-semibold text-slate-900">Configurazione tecnica</h2>
						<button
							id="toggleConfigButton"
							type="button"
							class="rounded-xl border border-brand-300 bg-white px-4 py-2 text-sm font-semibold text-brand-700 hover:bg-brand-50"
						>
							Apri configurazione tecnica
						</button>
					</div>
					<p class="mt-2 text-sm text-slate-700">
						Questa sezione serve solo per setup iniziale o manutenzione. Durante l'uso normale puo restare chiusa.
					</p>
					<div id="configPanel" class="mt-4 hidden">
					<div class="mt-6 rounded-xl border border-slate-200 bg-white p-4">
						<h3 class="font-display text-lg font-semibold text-slate-900">Causali pagamento</h3>
						<p class="mt-1 text-sm text-slate-700">
							Una causale per riga. Questa lista alimenta il menu "Causale pagamento" nella sezione operazioni.
						</p>
						<label class="mt-3 block text-sm">
							<span class="mb-1 block font-medium text-slate-700">Elenco causali</span>
							<textarea
								id="expenseTypesTextarea"
								rows="8"
								class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none"
								placeholder="Es. Quota Campo"
							></textarea>
						</label>
						<div class="mt-3">
							<button
								id="saveExpenseTypesButton"
								type="button"
								class="rounded-xl bg-brand-700 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-800"
							>
								Salva causali
							</button>
						</div>
						<p id="expenseTypesStatus" class="status-message hidden" role="status"></p>
					</div>
					<div class="mt-4 rounded-xl border border-slate-200 bg-white p-4">
						<h3 class="font-display text-lg font-semibold text-slate-900">Metodi di pagamento</h3>
						<p class="mt-1 text-sm text-slate-700">
							Un metodo per riga. Questa lista alimenta i menu "Metodo pagamento" nella dashboard.
						</p>
						<label class="mt-3 block text-sm">
							<span class="mb-1 block font-medium text-slate-700">Elenco metodi</span>
							<textarea
								id="paymentMethodsTextarea"
								rows="4"
								class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none"
								placeholder="Es. Bancomat"
							></textarea>
						</label>
						<div class="mt-3">
							<button
								id="savePaymentMethodsButton"
								type="button"
								class="rounded-xl bg-brand-700 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-800"
							>
								Salva metodi
							</button>
						</div>
						<p id="paymentMethodsStatus" class="status-message hidden" role="status"></p>
					</div>
					<div class="mt-6 rounded-xl border border-slate-200 bg-white p-4">
						<h3 class="font-display text-lg font-semibold text-slate-900">Configurazione GitHub (una volta sola)</h3>
						<p class="mt-1 text-sm text-slate-700">
							Compila questi campi la prima volta sul PC della segreteria. Servono per aggiornare online il file dati.
						</p>
						<form id="githubConfigForm" class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Owner</span>
								<input id="githubOwner" required class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none" />
							</label>
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Repository</span>
								<input id="githubRepo" required class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none" />
							</label>
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Branch</span>
								<input id="githubBranch" value="main" required class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none" />
							</label>
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Path file dati</span>
								<input id="githubDataPath" value="public/data/club-data.json" required class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none" />
							</label>
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Token (PAT)</span>
								<input id="githubToken" type="password" required class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none" />
							</label>
							<div class="sm:col-span-2 lg:col-span-5">
								<button type="submit" class="rounded-xl bg-brand-700 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-800">
									Salva configurazione
								</button>
							</div>
						</form>
						<p id="configStatus" class="status-message hidden" role="status"></p>
					</div>
					</div>
				</section>

				<section class="glass-card p-5">
						<div class="flex flex-wrap items-center justify-between gap-3">
							<h2 class="font-display text-xl font-semibold text-slate-900">Anagrafica soci</h2>
							<button
								id="toggleMembersButton"
								type="button"
								class="rounded-xl border border-brand-300 bg-white px-4 py-2 text-sm font-semibold text-brand-700 hover:bg-brand-50"
							>
								Apri anagrafica soci
							</button>
						</div>
						<div id="membersPanel" class="mt-4 hidden">
						<form id="memberForm" class="grid gap-3 sm:grid-cols-3">
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Cognome</span>
								<input id="memberSurname" required class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none" />
							</label>
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Nome</span>
								<input id="memberName" required class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none" />
							</label>
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Codice fiscale</span>
								<input id="memberTaxCode" required class="w-full rounded-xl border border-slate-300 px-3 py-2 uppercase focus:border-brand-600 focus:outline-none" />
							</label>
							<div class="sm:col-span-3">
								<button
									id="memberSubmitButton"
									type="submit"
									class="rounded-xl bg-brand-700 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-800"
								>
									Aggiungi socio
								</button>
							</div>
						</form>
						<p id="memberStatus" class="status-message hidden" role="status"></p>
						<div class="mt-4 overflow-auto rounded-xl border border-slate-200 bg-white">
							<table class="min-w-full text-left text-sm">
								<thead class="bg-slate-50 text-xs uppercase tracking-[0.12em] text-slate-600">
									<tr>
										<th class="px-3 py-2">N.</th>
										<th class="px-3 py-2">Cognome</th>
										<th class="px-3 py-2">Nome</th>
										<th class="px-3 py-2">Codice fiscale</th>
										<th class="px-3 py-2">Azioni</th>
									</tr>
								</thead>
								<tbody id="membersTableBody"></tbody>
							</table>
						</div>
						</div>
				</section>

				<section class="glass-card p-5">
						<h2 class="font-display text-xl font-semibold text-slate-900">Nuova operazione</h2>
						<form id="transactionForm" class="mt-4 grid gap-3 sm:grid-cols-2">
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">ID ricevuta</span>
								<input id="receiptId" readonly class="w-full rounded-xl border border-slate-300 bg-slate-100 px-3 py-2" />
							</label>
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Data</span>
								<input id="transactionDate" type="date" required class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none" />
							</label>
							<label class="text-sm sm:col-span-2">
								<span class="mb-1 block font-medium text-slate-700">Socio</span>
								<select id="memberSelect" required class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none"></select>
							</label>
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Causale pagamento</span>
								<select id="expenseType" required class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none">
									<option value="Quota campo">Quota campo</option>
									<option value="Lezione">Lezione</option>
									<option value="Palline">Palline</option>
									<option value="Altro">Altro</option>
								</select>
							</label>
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Metodo pagamento</span>
								<select id="paymentMethod" required class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none">
									<option value="Bancomat">Bancomat</option>
									<option value="Contanti">Contanti</option>
								</select>
							</label>
							<label class="text-sm sm:col-span-2">
								<span class="mb-1 block font-medium text-slate-700">Importo (EUR)</span>
								<input id="amountInput" type="number" min="0" step="0.01" required class="w-full rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none" placeholder="es. 10.00" />
							</label>
							<div class="sm:col-span-2">
								<button type="submit" class="rounded-xl bg-brand-700 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-800">
									Salva operazione
								</button>
							</div>
						</form>
						<p id="operationStatus" class="status-message hidden" role="status"></p>
				</section>

				<section class="glass-card p-5">
					<div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
						<div>
							<h2 class="font-display text-xl font-semibold text-slate-900">Crea ricevute</h2>
							<p class="text-sm text-slate-700">Crea ed esporta i report trimestrali.</p>
						</div>
						<form id="reportForm" class="flex flex-wrap items-end gap-3">
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Anno</span>
								<input id="reportYear" type="number" min="2020" max="2100" class="w-28 rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none" />
							</label>
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Trimestre</span>
								<select id="reportQuarter" class="w-28 rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none">
									<option value="1">Q1</option>
									<option value="2">Q2</option>
									<option value="3">Q3</option>
									<option value="4">Q4</option>
								</select>
							</label>
							<label class="text-sm">
								<span class="mb-1 block font-medium text-slate-700">Metodo</span>
								<select id="reportPaymentFilter" class="w-36 rounded-xl border border-slate-300 px-3 py-2 focus:border-brand-600 focus:outline-none">
									<option value="all">Entrambi</option>
									<option value="Bancomat">Solo Bancomat</option>
									<option value="Contanti">Solo Contanti</option>
								</select>
							</label>
							<button type="submit" class="rounded-xl bg-brand-700 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-800">
								Esporta PDF
							</button>
							<button
								id="bulkGenerateReceiptsButton"
								type="button"
								class="rounded-xl border border-emerald-300 bg-white px-4 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50"
							>
								Genera ricevute mancanti
							</button>
						</form>
					</div>
					<p id="receiptsStatus" class="status-message hidden" role="status"></p>
					<div class="mt-4 grid gap-3 sm:grid-cols-3">
						<div class="rounded-xl border border-slate-200 bg-white p-4">
							<p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">Entrate Contanti</p>
							<p id="summaryContanti" class="mt-1 text-lg font-bold text-slate-900">€0,00</p>
						</div>
						<div class="rounded-xl border border-slate-200 bg-white p-4">
							<p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">Entrate Bancomat</p>
							<p id="summaryBancomat" class="mt-1 text-lg font-bold text-slate-900">€0,00</p>
						</div>
						<div class="rounded-xl border border-slate-200 bg-white p-4">
							<p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">Entrate totali</p>
							<p id="summaryTotal" class="mt-1 text-lg font-bold text-slate-900">€0,00</p>
						</div>
					</div>
					<div class="mt-4 overflow-auto rounded-xl border border-slate-200 bg-white">
						<table class="min-w-full text-left text-sm">
							<thead class="bg-slate-50 text-xs uppercase tracking-[0.12em] text-slate-600">
								<tr>
									<th class="px-3 py-2">Ricevuta</th>
									<th class="px-3 py-2">Data</th>
									<th class="px-3 py-2">Cliente</th>
									<th class="px-3 py-2">Codice fiscale</th>
									<th class="px-3 py-2">Causale</th>
									<th class="px-3 py-2">Metodo</th>
									<th class="px-3 py-2">Importo</th>
									<th class="px-3 py-2">Azioni</th>
								</tr>
							</thead>
							<tbody id="transactionsTableBody"></tbody>
						</table>
					</div>
				</section>
			</section>
		</main>
		<div id="bulkSaveOverlay" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/50 px-4">
			<div class="w-full max-w-md rounded-2xl bg-white p-5 shadow-2xl">
				<p class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-500">Salvataggio ricevute</p>
				<p id="bulkSaveMessage" class="mt-2 text-sm text-slate-700">Preparazione in corso...</p>
				<div class="mt-4 h-2 w-full overflow-hidden rounded-full bg-slate-200">
					<div id="bulkSaveProgressBar" class="h-full w-0 rounded-full bg-brand-700 transition-all"></div>
				</div>
			</div>
		</div>

		<script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
		<script src="https://cdn.jsdelivr.net/npm/jspdf-autotable@3.8.2/dist/jspdf.plugin.autotable.min.js"></script>
		<script define:vars={{ dataPath, logoReceiptPath }}>
			const DEFAULT_PASSWORD = 'village123';
			const STORAGE_KEYS = {
				password: 'village_admin_password',
				access: 'village_admin_access',
				githubConfig: 'village_github_config'
			};

			const authBox = document.getElementById('authBox');
			const adminApp = document.getElementById('adminApp');
			const authStatus = document.getElementById('authStatus');
			const unlockForm = document.getElementById('unlockForm');
			const adminPasswordInput = document.getElementById('adminPasswordInput');
			const githubConfigForm = document.getElementById('githubConfigForm');
			const configStatus = document.getElementById('configStatus');
			const toggleConfigButton = document.getElementById('toggleConfigButton');
			const configPanel = document.getElementById('configPanel');
			const memberForm = document.getElementById('memberForm');
			const memberSubmitButton = document.getElementById('memberSubmitButton');
			const memberStatus = document.getElementById('memberStatus');
			const membersTableBody = document.getElementById('membersTableBody');
			const toggleMembersButton = document.getElementById('toggleMembersButton');
			const membersPanel = document.getElementById('membersPanel');
			const memberSelect = document.getElementById('memberSelect');
			const transactionForm = document.getElementById('transactionForm');
			const transactionsTableBody = document.getElementById('transactionsTableBody');
			const adminGlobalStatus = document.getElementById('adminGlobalStatus');
			const operationStatus = document.getElementById('operationStatus');
			const receiptsStatus = document.getElementById('receiptsStatus');
			const receiptIdInput = document.getElementById('receiptId');
			const transactionDateInput = document.getElementById('transactionDate');
			const expenseTypeInput = document.getElementById('expenseType');
			const paymentMethodInput = document.getElementById('paymentMethod');
			const amountInput = document.getElementById('amountInput');
			const reportForm = document.getElementById('reportForm');
			const bulkGenerateReceiptsButton = document.getElementById('bulkGenerateReceiptsButton');
			const reportYearInput = document.getElementById('reportYear');
			const reportQuarterInput = document.getElementById('reportQuarter');
			const reportPaymentFilterInput = document.getElementById('reportPaymentFilter');
			const summaryTotal = document.getElementById('summaryTotal');
			const summaryBancomat = document.getElementById('summaryBancomat');
			const summaryContanti = document.getElementById('summaryContanti');
			const expenseTypesTextarea = document.getElementById('expenseTypesTextarea');
			const saveExpenseTypesButton = document.getElementById('saveExpenseTypesButton');
			const expenseTypesStatus = document.getElementById('expenseTypesStatus');
			const paymentMethodsTextarea = document.getElementById('paymentMethodsTextarea');
			const savePaymentMethodsButton = document.getElementById('savePaymentMethodsButton');
			const paymentMethodsStatus = document.getElementById('paymentMethodsStatus');
			const bulkSaveOverlay = document.getElementById('bulkSaveOverlay');
			const bulkSaveMessage = document.getElementById('bulkSaveMessage');
			const bulkSaveProgressBar = document.getElementById('bulkSaveProgressBar');

			const githubOwnerInput = document.getElementById('githubOwner');
			const githubRepoInput = document.getElementById('githubRepo');
			const githubBranchInput = document.getElementById('githubBranch');
			const githubDataPathInput = document.getElementById('githubDataPath');
			const githubTokenInput = document.getElementById('githubToken');

			const today = new Date();
			const currentMonth = today.getMonth() + 1;
			const currentQuarter = Math.floor((currentMonth - 1) / 3) + 1;
			reportYearInput.value = String(today.getFullYear());
			reportQuarterInput.value = String(currentQuarter);
			transactionDateInput.value = today.toISOString().slice(0, 10);

			let clubData = { members: [], transactions: [], settings: { expenseTypes: [], paymentMethods: [] } };
			let memberEditingId = null;
			let transactionEditingId = null;
			let transactionRowError = { id: null, message: '' };
			let saveQueue = Promise.resolve();
			const DEFAULT_EXPENSE_TYPES = [
				'Quota Campo',
				'Quota Tessera Socio',
				'Lezione Privata',
				'Lezione Doppia',
				'Corso Settimanale',
				'Quota campo + quota associativa',
				'Contributo Kit allenamento',
				'Corso Mensile',
				'Quota campo lezione partita',
				'Corso Trimestrale accademy',
				'Quota Iscrizione Campionato'
			];
			const DEFAULT_PAYMENT_METHODS = ['Bancomat', 'Contanti', 'Bonifico'];
			const DEFAULT_EXPENSE_AMOUNTS = {
				'quota campo': 10,
				'lezione privata': 25,
				'lezione doppia': 35,
				'quota iscrizione campionato': 25,
				'corso mensile': 100
			};
			const RECEIPT_ISSUER = {
				name: 'ASD Village Fregene Padel',
				address: 'Via Agropoli 85, Fregene Fiumicino (RM) 00054',
				taxCode: '96530260585',
				phone: '3272844757'
			};

			function parseJSONSafely(text, fallback) {
				try {
					const parsed = JSON.parse(text);
					if (!parsed || typeof parsed !== 'object') return fallback;
					return parsed;
				} catch {
					return fallback;
				}
			}

			function loadPassword() {
				return localStorage.getItem(STORAGE_KEYS.password) || DEFAULT_PASSWORD;
			}

			function formatCurrency(value) {
				return new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR' }).format(value);
			}

			function formatDateIt(isoDate) {
				if (!isoDate) return '';
				const date = new Date(`${isoDate}T00:00:00`);
				if (Number.isNaN(date.getTime())) return isoDate;
				return date.toLocaleDateString('it-IT');
			}

			const STATUS_MESSAGE_BASE = 'status-message mt-3 rounded-xl border px-3 py-2 text-sm font-medium';

			function getStatusMessageClass(type = 'info', includeTopMargin = true) {
				const base = includeTopMargin
					? STATUS_MESSAGE_BASE
					: 'status-message rounded-xl border px-4 py-3 text-sm font-medium';
				const variants = {
					success: `${base} border-emerald-200 bg-emerald-50 text-emerald-800`,
					error: `${base} border-red-200 bg-red-50 text-red-800`,
					info: `${base} border-slate-200 bg-slate-50 text-slate-700`
				};
				return variants[type] || variants.info;
			}

			function setStatusMessage(element, message, type = 'info', options = {}) {
				if (!element) return;
				if (!message) {
					element.textContent = '';
					element.className = 'status-message hidden';
					return;
				}
				element.textContent = message;
				element.className = getStatusMessageClass(type, options.includeTopMargin !== false);
			}


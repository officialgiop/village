			function resolveTransactionPerson(tx) {
				const linkedMember = tx.memberId ? clubData.members.find((item) => item.id === tx.memberId) : null;
				if (linkedMember) {
					return {
						client: `${linkedMember.name} ${linkedMember.surname}`.trim(),
						taxCode: String(linkedMember.taxCode || '').toUpperCase() || '#N/A',
						hasIssue: Boolean(tx.hasIssue),
						issue: tx.issue || ''
					};
				}

				const fallbackClient = `${tx.memberName || ''} ${tx.memberSurname || ''}`.trim() || 'Socio non trovato';
				return {
					client: fallbackClient,
					taxCode: String(tx.memberTaxCode || '#N/A').toUpperCase(),
					hasIssue: true,
					issue: tx.issue || 'member_not_found'
				};
			}

			async function generateSingleReceiptPdf(tx) {
				const doc = await buildReceiptDocument([tx]);
				await savePdfWithPickerOrDownload(doc, `ricevuta-${tx.receiptId}.pdf`);
			}

			async function buildReceiptDocument(transactions) {
				const jsPDF = await ensurePdfLibraries();
				const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
				for (let index = 0; index < transactions.length; index += 1) {
					if (index > 0) doc.addPage();
					await drawReceiptPage(doc, transactions[index]);
				}
				return doc;
			}

			async function savePdfWithPickerOrDownload(doc, defaultFileName) {
				const blob = doc.output('blob');
				if ('showSaveFilePicker' in window) {
					const handle = await window.showSaveFilePicker({
						suggestedName: defaultFileName,
						types: [
							{
								description: 'PDF document',
								accept: { 'application/pdf': ['.pdf'] }
							}
						]
					});
					const writable = await handle.createWritable();
					await writable.write(blob);
					await writable.close();
					return;
				}
				doc.save(defaultFileName);
			}

			async function savePdfToDirectoryHandle(doc, directoryHandle, fileName) {
				const fileHandle = await directoryHandle.getFileHandle(fileName, { create: true });
				const writable = await fileHandle.createWritable();
				await writable.write(doc.output('blob'));
				await writable.close();
			}

			function showBulkSaveOverlay(total) {
				if (!bulkSaveOverlay || !bulkSaveMessage || !bulkSaveProgressBar) return;
				bulkSaveOverlay.classList.remove('hidden');
				bulkSaveOverlay.classList.add('flex');
				updateBulkSaveProgress(0, total);
			}

			function updateBulkSaveProgress(done, total) {
				if (!bulkSaveMessage || !bulkSaveProgressBar) return;
				const safeTotal = Math.max(1, Number(total) || 1);
				const safeDone = Math.min(Math.max(0, Number(done) || 0), safeTotal);
				const percent = Math.round((safeDone / safeTotal) * 100);
				bulkSaveMessage.textContent = `Salvataggio ricevute ${safeDone} / ${safeTotal}`;
				bulkSaveProgressBar.style.width = `${percent}%`;
			}

			function hideBulkSaveOverlay() {
				if (!bulkSaveOverlay) return;
				bulkSaveOverlay.classList.add('hidden');
				bulkSaveOverlay.classList.remove('flex');
			}

